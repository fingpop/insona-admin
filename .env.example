# Database configuration
# In Docker: file:/app/data/dev.db
# Local development: file:./prisma/dev.db
DATABASE_URL="file:/app/data/dev.db"

# inSona gateway connection
# Must be reachable from the server/container network
# For gateway running on the same host: use "host.docker.internal"
# For gateway on another machine: use its IP address
GATEWAY_IP="192.168.1.100"
GATEWAY_PORT=8091
